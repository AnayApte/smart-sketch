{
  "name": "smart-sketch",
  "version": "0.1.0",
  "private": true,
  "description": "Live lecture visualization tool using LiveKit and ReactFlow",
  "scripts": {
    "dev": "next dev",
    "dev:agent": "python \"agent/main.py\" dev",
    "dev:full": "concurrently -n web,agent -c cyan,magenta \"npm run dev\" \"npm run dev:agent\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@livekit/components-react": "^2.0.0",
    "@livekit/rtc-node": "^0.7.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/typography": "^0.5.19",
    "livekit-client": "^2.0.0",
    "livekit-server-sdk": "^2.0.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.10.4",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
