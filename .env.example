# Environment Variables Template
# Copy this file to .env.local and fill in your values
#
# API routes (LiveKit token, Gemini chat/transcript, compress) require a
# signed-in user: the browser sends Authorization: Bearer <access_token>.

# LiveKit Configuration
# LIVEKIT_URL (or NEXT_PUBLIC_LIVEKIT_URL) is used server-side to explicitly dispatch the Python agent to each room.
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Google Gemini (transcript → concepts, Sketch Discussion chat, model list)
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: first model (default gemini-2.0-flash). On quota/rate-limit, other models are tried automatically.
# GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated models after GEMINI_MODEL (before built-in tail).
# GEMINI_MODEL_FALLBACKS=gemini-3-flash,gemini-1.5-flash
# Optional: full ordered chain (if set, GEMINI_MODEL / GEMINI_MODEL_FALLBACKS are ignored).
# GEMINI_MODEL_CHAIN=gemini-2.5-flash,gemini-3-flash,gemini-3.1-flash-lite,gemini-2.0-flash

# Next.js Configuration
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Supabase (auth + saved sessions). Anon JWT from Dashboard → Settings → API (not the service_role key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

