# ===========================================
# SmartSketch Agent Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then edit .env with your actual API keys
# ===========================================

# -----------------
# LIVEKIT SETTINGS
# -----------------
# Get these from your LiveKit Cloud dashboard: https://cloud.livekit.io
# 1. Create a project (or use existing)
# 2. Go to Settings > Keys
# 3. Copy the values below

# The WebSocket URL for your LiveKit server
# Format: wss://your-project-name.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud

# Your LiveKit API Key (starts with API...)
LIVEKIT_API_KEY=APIxxxxxxxxxx

# Your LiveKit API Secret (long random string)
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The worker registers as agent_name "smartsketch-worker" (must match
# SMARTSKETCH_AGENT_NAME in the Next app: src/lib/livekit-agent.ts).

# -----------------
# DEEPGRAM SETTINGS
# -----------------
# Deepgram converts speech to text
# Get your API key: https://deepgram.com
# 1. Sign up (free tier gives you $200 credit)
# 2. Go to API Keys
# 3. Create a new key

DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------
# GOOGLE GEMINI SETTINGS
# -----------------
# Gemini extracts concepts from batched transcripts (same family as the Next.js routes).
# Create a key: https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-api-key
# Optional: first model (default gemini-2.0-flash); same fallback chain as Next.js on quota/rate-limit.
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACKS=gemini-3-flash,gemini-1.5-flash
# GEMINI_MODEL_CHAIN=gemini-2.5-flash,gemini-3.1-flash-lite,gemini-2.0-flash
